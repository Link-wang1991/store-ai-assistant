# ============ 数据源（选哪个模式查数据）============
# supabase → 前端直连 Supabase（无需部署后端，省钱）
# backend  → 走 Spring Boot 后端代理
NEXT_PUBLIC_DATA_SOURCE=supabase

# ============ Spring Boot 后端地址（仅 backend 模式需要）============
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# ============ Supabase（supabase 模式使用）============
# 在 https://supabase.com 创建项目后，从 Project Settings → API 获取
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role 仅服务端使用（seed、绕过 RLS 的管理操作），切勿写成 NEXT_PUBLIC_ 也勿暴露前端
SUPABASE_SERVICE_ROLE_KEY=

# ============ AI 模型（可切换）============
# 可选值：mock | deepseek | qwen
AI_PROVIDER=mock

# DeepSeek（文本问答 / 日报 / 话术 / 员工分析）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=

# Qwen 通义（图片识别 vision / 语音 audio）
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_TEXT_MODEL=
QWEN_VISION_MODEL=
QWEN_AUDIO_MODEL=

# ============ 文件存储（可选）============
# none | supabase
STORAGE_PROVIDER=
SUPABASE_STORAGE_BUCKET=

# ============ 演示模式 / 应用 ============
# true 时 /start 显示演示账号与一键登录；生产环境设 false
NEXT_PUBLIC_DEMO_MODE=
NEXT_PUBLIC_APP_NAME=

# ============ 定时任务（老板日报自动生成）============
# 部署到 Vercel 时设置，Cron 调用 /api/cron/daily-report 时校验；本地可留空
CRON_SECRET=
