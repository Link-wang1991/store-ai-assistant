{
  "name": "store-ai-assistant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev -H 0.0.0.0 -p 3000",
    "dev:https": "next dev --experimental-https -H 0.0.0.0 -p 3000",
    "dev:https-cert": "next dev --experimental-https --experimental-https-key ./certificates/key.pem --experimental-https-cert ./certificates/cert.pem -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint ."
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "ffmpeg-static": "^5.3.0",
    "mammoth": "^1.8.0",
    "next": "16.2.10",
    "officeparser": "^7.2.1",
    "pdf-parse": "^1.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "read-excel-file": "9.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "postcss": "8.5.19",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3"
  }
